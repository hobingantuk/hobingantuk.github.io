---
import { Wrench } from "lucide-react";
---

<div class="relative flex flex-col items-center justify-center">
    <!-- Wrench Icon -->
    <div
        class="bg-secondary/20 p-4 rounded-lg shadow-lg shadow-primary/30 animate-pulse"
    >
        <Wrench
            className="w-16 h-16 text-primary drop-shadow-[0_0_10px_var(--color-primary)]"
        />
    </div>

    <!-- Title -->
    <h1 class="mt-6 text-4xl font-nis-m9-condensed text-primary text-center">
        🚧 Whoops! Page is Still Cooking...
    </h1>

    <!-- Description -->
    <p
        class="mt-2 text-muted-primary font-matisse-classic text-center max-w-lg"
    >
        Hey, you caught me mid-development! I'm currently adding out details the
        details, adding features , and making this page less boring. <br />
        Please come back later!!!
    </p>
</div>
