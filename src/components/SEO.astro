---
interface Props {
    title: string;
    description?: string;
    canonical?: string;
    ogImage?: string;
}

const siteName = "Bagus Maulana Nugraha - Fullstack Software Engineer";

const defaultDesc =
    "Bagus Maulana Nugraha is a Full-Stack Software Engineer specializing in Java, Spring Boot, .NET, React, and cloud-native systems. Portfolio featuring backend engineering, DevOps, distributed systems, and modern web applications.";
const siteURL = Astro.site?.toString() ?? "https://bmnugraha.com";
const canonical = Astro.props.canonical || `${siteURL}${Astro.url.pathname}`;

const documentTitle = `${Astro.props.title} | ${siteName}`;
const documentDescription = Astro.props.description || defaultDesc;

// Ensure an OG image exists for better sharing previews
const ogImage = Astro.props.ogImage || `${siteURL}/images/ogimage.png`;

// Keyword optimization for search ranking with multiple name variations
const keywords =
    "Bagus Nugraha,bmnugraha, Bagus Maulana Nugraha, hobingantuk, Software Engineer, Java, .NET, Laravel, React, Full-Stack Developer, DevOps, Fontys, ITS, Double Degree, Cloud, Automation, Software Architecture";

const schemaData = {
    "@context": "https://schema.org",
    "@type": "Person",
    "@id": `${siteURL}#person`,

    name: "Bagus Maulana Nugraha",
    alternateName: [
        "Bagus Nugraha",
        "hobingantuk",
        "Bagus",
        "bmnugraha",
        "bnugraha",
    ],
    jobTitle: ["Full-Stack Software Engineer", "Backend Engineer"],
    url: siteURL,
    sameAs: [
        "https://github.com/hobingantuk",
        "https://linkedin.com/in/bagusnugraha",
        "https://twitter.com/atleteskapisme",
        "https://bmnugraha.com",
    ],
    description: documentDescription,
    image: ogImage,

    alumniOf: [
        {
            "@type": "CollegeOrUniversity",
            name: "Fontys University of Applied Sciences",
        },
        {
            "@type": "CollegeOrUniversity",
            name: "Institut Teknologi Sepuluh Nopember",
        },
    ],

    knowsLanguage: ["English", "Indonesian"],

    knowsAbout: [
        "Full-Stack Web Development",
        "Backend Engineering",
        "Software Architecture",
        "Microservices Architecture",

        "DevOps",
        "CI/CD pipelines",
        "Containerization",
        "Infrastructure automation",

        "Java",
        "Spring Boot",
        ".NET Core",
        "PHP",
        "Laravel",
        "React",
        "TypeScript",

        "Docker",
        "Kubernetes",
        "OpenShift",
        "Ansible",
    ],
};
---

<head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />

    <!-- Title with strong personal branding for search engines -->
    <title>{documentTitle}</title>

    <!-- Essential SEO metadata -->
    <meta name="description" content={documentDescription} />
    <meta name="keywords" content={keywords} />
    <meta name="author" content="Bagus Maulana Nugraha" />

    <!-- Open Graph (OG) for better social media previews (Facebook, LinkedIn) -->
    <meta property="og:title" content={documentTitle} />
    <meta property="og:description" content={documentDescription} />
    <meta property="og:type" content="website" />
    <meta property="og:url" content={canonical} />
    <meta property="og:image" content={ogImage} />
    <meta property="og:site_name" content={siteName} />

    <!-- Twitter Card for better Twitter SEO -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={documentTitle} />
    <meta name="twitter:description" content={documentDescription} />
    <meta name="twitter:image" content={ogImage} />
    <meta name="twitter:url" content={canonical} />
    <meta name="twitter:creator" content="@atleteskapisme" />
    <!-- Your correct Twitter handle -->

    <meta name="generator" content={Astro.generator} />

    <!-- Canonical URL for preventing duplicate content issues -->
    <link rel="canonical" href={canonical} />
    <link
        rel="sitemap"
        type="application/xml"
        title="Sitemap"
        href="/sitemap-index.xml"
    />

    <meta name="robots" content="index, follow, max-image-preview:large" />

    <!-- Favicon & App Icons -->
    <link rel="icon" href="/favicon.ico" />
    <link
        rel="icon"
        type="image/png"
        href="/favicon/favicon-96x96.png"
        sizes="96x96"
    />
    <link rel="icon" type="image/svg+xml" href="/favicon/favicon.svg" />
    <link rel="shortcut icon" href="/favicon/favicon.ico" />
    <link
        rel="apple-touch-icon"
        sizes="180x180"
        href="/favicon/apple-touch-icon.png"
    />
    <link rel="manifest" href="/favicon/site.webmanifest" />
    <!--

  <link rel="preload" href="/fonts/NIS-JTC-Win-M9-Condensed.woff2" as="font" type="font/woff2" crossorigin="anonymous" />
  <link rel="preload" href="/fonts/TimesNewRomanMTCondensedRegular.woff2" as="font" type="font/woff2" crossorigin="anonymous" /> -->
</head>
<script type="application/ld+json" set:html={JSON.stringify(schemaData)} />
